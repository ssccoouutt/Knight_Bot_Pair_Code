# Clone fresh
git clone https://github.com/ssccoouutt/WA-Session-API.git
cd WA-Session-API

# Remove existing lockfile if any
rm -f package-lock.json

# Install with npm to generate proper lockfile
npm install

# Verify lockfile was created
ls -la package-lock.json

# Commit and push
git add package-lock.json
git commit -m "Fix: Generate valid package-lock.json"
git push origin main
